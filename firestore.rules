rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function bookDoc(bookId) {
      return get(/databases/$(database)/documents/householdBooks/$(bookId));
    }

    function isBookOwner(bookId) {
      return isAuthenticated()
        && bookDoc(bookId).data.ownerId == request.auth.uid;
    }

    function isBookParticipant(bookId) {
      return isAuthenticated()
        && bookDoc(bookId).data.participantIds is list
        && request.auth.uid in bookDoc(bookId).data.participantIds;
    }

    function canAccessBook(bookId) {
      return isBookOwner(bookId) || isBookParticipant(bookId);
    }

    match /householdBooks/{bookId} {
      function isOwner() {
        return isAuthenticated()
          && resource.data.ownerId == request.auth.uid;
      }

      function isParticipant() {
        return isAuthenticated()
          && resource.data.participantIds is list
          && request.auth.uid in resource.data.participantIds;
      }

      allow read: if isOwner() || isParticipant();

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 0
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      allow update: if isOwner()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.participantIds is list;
    }

    match /categories/{categoryId} {
      allow read: if canAccessBook(resource.data.bookId);

      allow create: if isAuthenticated()
        && request.resource.data.bookId is string
        && isBookOwner(request.resource.data.bookId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.maxBudget is number;

      allow update, delete: if isBookOwner(resource.data.bookId);
    }

    match /transactions/{transactionId} {
      allow read: if canAccessBook(resource.data.bookId);

      allow create: if isAuthenticated()
        && request.resource.data.bookId is string
        && canAccessBook(request.resource.data.bookId)
        && request.resource.data.amount is number
        && request.resource.data.type in ["income", "expense"];

      allow update, delete: if isBookOwner(resource.data.bookId);
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function bookDoc(bookId) {
      return get(/databases/$(database)/documents/householdBooks/$(bookId));
    }

    function isBookOwner(bookId) {
      return isAuthenticated()
        && bookDoc(bookId).data.ownerId == request.auth.uid;
    }

    function isBookParticipant(bookId) {
      return isAuthenticated()
        && request.auth.uid in bookDoc(bookId).data.participantIds;
    }

    function canAccessBook(bookId) {
      return (isBookOwner(bookId) || isBookParticipant(bookId))
        && bookDoc(bookId).data.isArchived == false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create, update: if isAuthenticated()
        && userId == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.emailLower is string;
    }

    match /householdBooks/{bookId} {
      function isOwner() {
        return isAuthenticated()
          && resource.data.ownerId == request.auth.uid;
      }

      function isParticipant() {
        return isAuthenticated()
          && request.auth.uid in resource.data.participantIds;
      }

      allow read: if isOwner() || isParticipant();

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 0
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 50;

      allow update: if isOwner()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 50
        && request.resource.data.participantIds is list;
    }

    match /categories/{categoryId} {
      allow read: if canAccessBook(resource.data.bookId);

      allow create: if isAuthenticated()
        && request.resource.data.bookId is string
        && isBookOwner(request.resource.data.bookId)
        && bookDoc(request.resource.data.bookId).data.isArchived == false
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.maxBudget is number
        && request.resource.data.maxBudget >= 0;

      allow update: if isBookOwner(resource.data.bookId)
        && bookDoc(resource.data.bookId).data.isArchived == false
        && request.resource.data.bookId == resource.data.bookId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.maxBudget is number
        && request.resource.data.maxBudget >= 0;

      allow delete: if isBookOwner(resource.data.bookId)
        && bookDoc(resource.data.bookId).data.isArchived == false;
    }

    match /transactions/{transactionId} {
      allow read: if canAccessBook(resource.data.bookId);

      allow create: if isAuthenticated()
        && request.resource.data.bookId is string
        && isBookOwner(request.resource.data.bookId)
        && bookDoc(request.resource.data.bookId).data.isArchived == false
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.type in ["expense", "income"];

      allow update: if isBookOwner(resource.data.bookId)
        && bookDoc(resource.data.bookId).data.isArchived == false
        && request.resource.data.bookId == resource.data.bookId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.type in ["expense", "income"];

      allow delete: if isBookOwner(resource.data.bookId)
        && bookDoc(resource.data.bookId).data.isArchived == false;
    }
  }
}
